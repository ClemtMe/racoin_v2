{
    "require": {
        "php": ">=8.2",
        "slim/slim": "3.*",
        "twig/twig": "3.*",
        "illuminate/database": "11.*",
        "ext-mysqli": "*",
        "ext-pdo": "*"
    },
    "autoload":{
        "psr-0":{
            "controller":"",
            "model":"",
            "db":""
        }
    },
    "config": {
        "allow-plugins": {
            "kylekatarnls/update-helper": true,
            "phpstan/extension-installer": true
        }
    },
    "require-dev": {
        "phpunit/phpunit": "^11.5",
        "mockery/mockery": "^1.6",
        "phpstan/phpstan": "^2.1"
    },
    "scripts": {
        "test": "phpunit",
        "phpstan": "phpstan analyse"
    }
}
